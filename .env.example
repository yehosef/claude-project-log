# claude-project-log environment variables
# Copy to ~/.claude/projects-log/.env and run: chmod 600 ~/.claude/projects-log/.env

# Required: Notion internal integration token
# Get one at https://www.notion.so/my-integrations ("New integration", copy the secret)
NOTION_TOKEN=

# Optional but recommended: Anthropic API key for reliable headless synthesis
# Without this, the sweeper uses your claude CLI subscription credentials,
# which can be blocked by macOS keychain under launchd (non-interactive session).
# ANTHROPIC_API_KEY=
